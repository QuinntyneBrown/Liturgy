{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "liturgy-app": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss",
          "skipTests": true
        },
        "@schematics/angular:class": {
          "skipTests": true
        },
        "@schematics/angular:directive": {
          "skipTests": true
        },
        "@schematics/angular:guard": {
          "skipTests": true
        },
        "@schematics/angular:interceptor": {
          "skipTests": true
        },
        "@schematics/angular:pipe": {
          "skipTests": true
        },
        "@schematics/angular:resolver": {
          "skipTests": true
        },
        "@schematics/angular:service": {
          "skipTests": true
        }
      },
      "root": "projects/liturgy-app",
      "sourceRoot": "projects/liturgy-app/src",
      "prefix": "lit",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/liturgy-app/src/main.ts",
            "tsConfig": "projects/liturgy-app/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/liturgy-app/public"
              }
            ],
            "styles": ["projects/liturgy-app/src/styles.scss"]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "700kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "liturgy-app:build:production"
            },
            "development": {
              "buildTarget": "liturgy-app:build:development"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    },
    "@liturgy/api": {
      "projectType": "library",
      "root": "projects/liturgy/api",
      "sourceRoot": "projects/liturgy/api/src",
      "prefix": "lit",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/liturgy/api/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/liturgy/api/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/liturgy/api/tsconfig.spec.json"
          }
        }
      }
    },
    "@liturgy/components": {
      "projectType": "library",
      "root": "projects/liturgy/components",
      "sourceRoot": "projects/liturgy/components/src",
      "prefix": "lit",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/liturgy/components/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/liturgy/components/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/liturgy/components/tsconfig.spec.json"
          }
        }
      }
    },
    "@liturgy/domain": {
      "projectType": "library",
      "root": "projects/liturgy/domain",
      "sourceRoot": "projects/liturgy/domain/src",
      "prefix": "lit",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/liturgy/domain/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/liturgy/domain/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/liturgy/domain/tsconfig.spec.json"
          }
        }
      }
    }
  }
}
